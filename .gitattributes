# Normalisation des fins de ligne (projet multi-OS).
# Par defaut : LF dans le depot, conversion auto a la sortie.
* text=auto eol=lf

# Scripts Windows : doivent rester en CRLF.
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binaire / genere : pas de conversion.
*.png binary
*.gif binary
*.ttf binary
*.ico binary
