// Flowspire — EXEMPLE de structure d'un profil (référence de lecture).
//
// IMPORTANT : tu n'as normalement JAMAIS besoin d'éditer ce fichier à la main.
// Toute la configuration se fait dans OBS via l'assistant et les paramètres
// avancés du plugin. Ce fichier est fourni pour DOCUMENTER la structure JSON
// d'un profil (utile pour comprendre / inspecter tes fichiers).
//
// Où vivent les vrais profils (un fichier <id>.json par profil + index.json) :
//   Windows : %APPDATA%\obs-studio\plugin_config\flowspire\profiles\
//   macOS   : ~/Library/Application Support/obs-studio/plugin_config/flowspire/profiles/
//   Linux   : ~/.config/obs-studio/plugin_config/flowspire/profiles/
// (Le vrai JSON n'autorise pas les commentaires // : ils sont ici pour l'explication.)
//
// Les noms doivent correspondre EXACTEMENT à OBS :
//   - "audioSource" = nom EXACT de la source dans le mixer audio (ex: "Mic/Aux",
//     "Invité 1", "Desktop Audio"...). Respecte la casse.
//   - "scene"       = nom EXACT d'une scène OBS existante.
//
// LES POIDS (rappel) : ce sont des proportions relatives, PAS des pourcentages.
// gros plan 90 / plan large 10 => ~90% du temps le gros plan. Le % est calculé
// tout seul (tu n'as pas besoin que ça tombe sur 100).
{
  "version": 1,

  // --- Les intervenants : 1 par source audio à suivre ---
  "speakers": [
    {
      "id": "inv1",                       // identifiant interne (libre, unique)
      "name": "Invité 1",                 // nom affiché dans le dock
      "audioSource": "Invité 1",          // <-- TON nom de source audio OBS
      "scenes": [                         // scènes possibles QUAND l'invité 1 parle
        { "scene": "Invité 1 - gros plan", "weight": 90 },
        { "scene": "Plan large",           "weight": 10 }
      ]
    },
    {
      "id": "inv2",
      "name": "Invité 2",
      "audioSource": "Invité 2",
      "scenes": [
        { "scene": "Invité 2 - gros plan", "weight": 90 },
        { "scene": "Plan large",           "weight": 10 }
      ]
    },
    {
      "id": "moi",
      "name": "Moi (micro)",
      "audioSource": "Mic/Aux",           // <-- TON micro local
      "scenes": [
        { "scene": "Moi - gros plan",      "weight": 90 },
        { "scene": "Plan large",           "weight": 10 }
      ]
    }
  ],

  // --- Scène de groupe (plan d'ensemble). "" si tu n'en as pas ---
  "wideShotScene": "Plan large",

  // --- Détection audio (défauts Gabin ; ne touche que si besoin) ---
  "audio": {
    "voiceThresholdDb": -35.0,  // seuil "parle" : plus haut = moins sensible
    "attackFrames": 2,          // frames au-dessus du seuil avant "parle"
    "releaseFrames": 8          // frames sous le seuil avant "ne parle plus"
  },

  // --- Rythme des plans (secondes) ---
  "timing": {
    "minShotSeconds": 5.0,           // temps mini sur un plan (anti-nervosité)
    "maxShotSeconds": 12.0,          // au-delà : on rafraîchit le plan (variété)
    "pingPongWindowSeconds": 0.0,    // "retour au plan large sur échange rapide" : 0 = désactivé
                                     // (opt-in). Sur une navette A↔B rapide (chacun seul à son
                                     // tour), on se recule sur le plan large le temps que ça
                                     // respire. N'agit QUE si un plan large existe.
    "silenceReactionSeconds": 1.0,   // grâce de silence : délai avant de réagir à un blanc (on garde
                                     // le plan courant), évite de basculer sur une simple respiration.
                                     // 0 = réaction immédiate.
    "maxPlanRepeats": 0              // répétition max d'un MÊME plan avant respiration. 0 = désactivé
                                     // (opt-in). Au-delà de N : re-tirage pondéré dans le pool de la
                                     // personne PRIVÉ de ce plan (autre cam / réaction / plan large,
                                     // selon les poids). Compte PAR SCÈNE, jamais par intervenant. Les
                                     // styles livrés le règlent (Cool 5 … Very Fast 8).
  },

  // --- Quand PLUSIEURS parlent en même temps (tirage pondéré) ---
  // Le volume n'est PAS un critère ("le plus fort" a été retiré) : soit on reste sur le plan
  // courant, soit on passe au plan large.
  "whenMultiple": {
    "currentSpeaker": 30,   // rester sur le plan courant
    "wideShot": 25          // passer au plan large
  },

  // --- Quand PERSONNE ne parle (tirage pondéré) ---
  "whenSilence": {
    "lastSpeaker": 80,      // rester sur le dernier qui a parlé
    "wideShot": 20          // passer au plan large
  }
}
